{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "## Azure Virtual Desktop Lab\n\nDeploys a fully configured AVD environment including Entra ID-joined session hosts, FSLogix profile containers via Azure Files Premium v2, NAT Gateway, and Private Endpoint for storage.\n\n**Pre-requisites:**\n- A golden VM image (Managed Image or Shared Image Gallery version)\n- An Entra ID group called **AVD Users** containing your users\n- An Entra ID group called **AVD Devices** for Intune policy targeting",
        "location": {
          "label": "Region",
          "toolTip": "Region where all resources will be deployed.",
          "resourceTypes": [
            "Microsoft.DesktopVirtualization/hostPools",
            "Microsoft.Compute/virtualMachines",
            "Microsoft.Storage/storageAccounts"
          ]
        }
      }
    },
    "basics": [
      {
        "name": "prefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Resource prefix",
        "defaultValue": "avd-lab",
        "toolTip": "Short prefix applied to all resource names. For example avd-lab produces avd-lab-vnet, avd-lab-hp, etc.",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9-]{3,15}$",
          "validationMessage": "3 to 15 characters, lowercase letters, numbers and hyphens only."
        }
      }
    ],
    "steps": [
      {
        "name": "sessionHosts",
        "label": "Session Hosts",
        "subLabel": {
          "preValidation": "Configure your AVD virtual machines",
          "postValidation": "Done"
        },
        "elements": [
          {
            "name": "goldenImageInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "Paste the full resource ID of your golden image below. You can find this in the Azure Portal by navigating to your image resource and copying the JSON view resource ID."
            }
          },
          {
            "name": "goldenImageId",
            "type": "Microsoft.Common.TextBox",
            "label": "Golden image resource ID",
            "toolTip": "The full resource ID of your Managed Image or Shared Image Gallery version.",
            "placeholder": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-images/providers/Microsoft.Compute/images/avd-golden-image",
            "constraints": {
              "required": true,
              "regex": "^/subscriptions/[0-9a-fA-F-]{36}/resourceGroups/.+/providers/Microsoft\\.Compute/.+$",
              "validationMessage": "Must be a valid Azure resource ID for a Compute image or gallery image version."
            }
          },
          {
            "name": "vmCount",
            "type": "Microsoft.Common.DropDown",
            "label": "Number of session hosts",
            "defaultValue": "2",
            "toolTip": "How many session host VMs to deploy into the host pool.",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "1", "value": 1 },
                { "label": "2", "value": 2 },
                { "label": "3", "value": 3 },
                { "label": "4", "value": 4 }
              ]
            }
          },
          {
            "name": "vmSize",
            "type": "Microsoft.Common.DropDown",
            "label": "Session host VM size",
            "defaultValue": "Standard_D4s_v5",
            "toolTip": "Size for each session host VM. D-series v5 is recommended for AVD.",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "Standard_D2s_v5 (2 vCPU, 8 GB RAM)", "value": "Standard_D2s_v5" },
                { "label": "Standard_D4s_v5 (4 vCPU, 16 GB RAM) - recommended", "value": "Standard_D4s_v5" },
                { "label": "Standard_D8s_v5 (8 vCPU, 32 GB RAM)", "value": "Standard_D8s_v5" },
                { "label": "Standard_D16s_v5 (16 vCPU, 64 GB RAM)", "value": "Standard_D16s_v5" },
                { "label": "Standard_D2s_v4 (2 vCPU, 8 GB RAM)", "value": "Standard_D2s_v4" },
                { "label": "Standard_D4s_v4 (4 vCPU, 16 GB RAM)", "value": "Standard_D4s_v4" },
                { "label": "Standard_D8s_v4 (8 vCPU, 32 GB RAM)", "value": "Standard_D8s_v4" }
              ]
            }
          },
          {
            "name": "vmAdminUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Local admin username",
            "defaultValue": "avdadmin",
            "toolTip": "Local administrator account created on each session host.",
            "constraints": {
              "required": true,
              "regex": "^[a-zA-Z][a-zA-Z0-9-]{2,14}$",
              "validationMessage": "3 to 15 characters, must start with a letter. Letters, numbers and hyphens only."
            }
          },
          {
            "name": "vmAdminPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Local admin password",
              "confirmPassword": "Confirm password"
            },
            "toolTip": "Must be at least 12 characters and include uppercase, lowercase, a number, and a special character.",
            "constraints": {
              "required": true,
              "regex": "^(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z\\d]).{12,}$",
              "validationMessage": "Password must be at least 12 characters and include uppercase, lowercase, a number, and a special character."
            },
            "options": {
              "hideConfirmation": false
            }
          }
        ]
      },
      {
        "name": "identity",
        "label": "Identity and Access",
        "subLabel": {
          "preValidation": "Configure Entra ID groups",
          "postValidation": "Done"
        },
        "elements": [
          {
            "name": "identityInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "The AVD Users group will be granted Desktop Virtualization User on the App Group and SMB contributor access to the FSLogix file share. Find the Object ID in the Azure Portal under Entra ID > Groups > your group > Overview."
            }
          },
          {
            "name": "avdUsersGroupId",
            "type": "Microsoft.Common.TextBox",
            "label": "AVD Users group Object ID",
            "toolTip": "The Object ID of your AVD Users Entra ID security group.",
            "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
            "constraints": {
              "required": true,
              "regex": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
              "validationMessage": "Must be a valid GUID in the format xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx."
            }
          }
        ]
      },
      {
        "name": "fslogix",
        "label": "FSLogix and Storage",
        "subLabel": {
          "preValidation": "Configure profile container storage",
          "postValidation": "Done"
        },
        "elements": [
          {
            "name": "fslogixInfo",
            "type": "Microsoft.Common.InfoBox",
            "visible": true,
            "options": {
              "icon": "Info",
              "text": "FSLogix profiles are stored on an Azure Files Premium v2 share accessed via a Private Endpoint. The share quota is calculated as profile size multiplied by user count, with a minimum of 100 GB."
            }
          },
          {
            "name": "fslogixProfileSizeGB",
            "type": "Microsoft.Common.DropDown",
            "label": "Profile size per user (GB)",
            "defaultValue": "20 GB",
            "toolTip": "Maximum size of each user's FSLogix profile VHDX.",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "10 GB", "value": 10 },
                { "label": "20 GB", "value": 20 },
                { "label": "30 GB", "value": 30 },
                { "label": "40 GB", "value": 40 },
                { "label": "50 GB", "value": 50 },
                { "label": "75 GB", "value": 75 },
                { "label": "100 GB", "value": 100 }
              ]
            }
          },
          {
            "name": "fslogixUserCount",
            "type": "Microsoft.Common.DropDown",
            "label": "Number of users",
            "defaultValue": "4",
            "toolTip": "Total number of users who will have FSLogix profiles. Used to calculate the required file share quota.",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "1", "value": 1 },
                { "label": "2", "value": 2 },
                { "label": "3", "value": 3 },
                { "label": "4", "value": 4 },
                { "label": "5", "value": 5 },
                { "label": "10", "value": 10 },
                { "label": "15", "value": 15 },
                { "label": "20", "value": 20 },
                { "label": "25", "value": 25 },
                { "label": "30", "value": 30 },
                { "label": "40", "value": 40 },
                { "label": "50", "value": 50 }
              ]
            }
          },
          {
            "name": "storageAccountSku",
            "type": "Microsoft.Common.DropDown",
            "label": "Storage redundancy",
            "defaultValue": "Premium LRS (locally redundant)",
            "toolTip": "LRS is sufficient for a lab. ZRS provides zone redundancy for production.",
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "Premium LRS (locally redundant)", "value": "Premium_LRS" },
                { "label": "Premium ZRS (zone redundant)", "value": "Premium_ZRS" }
              ]
            }
          }
        ]
      }
    ],
    "outputs": {
      "location":             "[location()]",
      "prefix":               "[basics('prefix')]",
      "goldenImageId":        "[steps('sessionHosts').goldenImageId]",
      "vmAdminUsername":      "[steps('sessionHosts').vmAdminUsername]",
      "vmAdminPassword":      "[steps('sessionHosts').vmAdminPassword]",
      "vmSize":               "[steps('sessionHosts').vmSize]",
      "vmCount":              "[steps('sessionHosts').vmCount]",
      "avdUsersGroupId":      "[steps('identity').avdUsersGroupId]",
      "storageAccountSku":    "[steps('fslogix').storageAccountSku]",
      "fslogixProfileSizeGB": "[steps('fslogix').fslogixProfileSizeGB]",
      "fslogixUserCount":     "[steps('fslogix').fslogixUserCount]"
    }
  }
}
